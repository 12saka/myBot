# Database
DATABASE_URL=postgresql://trademind_user:trademind_secure_pass@localhost:5432/trademind_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=3600
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=604800

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=internal-secret-key

# External APIs
ALPACA_KEY=your-alpaca-api-key
ALPACA_SECRET=your-alpaca-secret
BINANCE_KEY=your-binance-api-key
BINANCE_SECRET=your-binance-secret

# Payments
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Sentry
SENTRY_DSN=your-sentry-dsn
