# Neon serverless PostgreSQL connection string (include ?sslmode=require)
DATABASE_URL="postgresql://[user]:[password]@[neon-project-id].neon.tech/[db-name]?sslmode=require"

# Redis
REDIS_URL="redis://localhost:6379"

# Security
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN=3600

# API Settings
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_API_KEY="internal-secret-key"

# External API Keys (Fill these to replace all simulated data)
GEMINI_API_KEY="your-google-gemini-api-key"
ALPACA_KEY="your-alpaca-paper-trading-api-key"
ALPACA_SECRET="your-alpaca-paper-trading-secret-key"
EXCHANGERATE_API_KEY="your-exchangerate-host-api-key"
