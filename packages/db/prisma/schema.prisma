generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String           @id @default(uuid())
  email              String           @unique
  phone              String?          @unique
  passwordHash       String
  role               Role             @default(TRADER)
  aiMode             AiMode           @default(BALANCED)
  twoFactorSecret    String?
  isTwoFactorEnabled Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  aiConversations    AIConversation[]
  accounts           Account[]
  amlAlerts          AmlRecord[]
  apiKeys            ApiKey[]
  auditLogs          AuditLog[]
  automationRules    AutomationRule[]
  certificates       Certificate[]
  devices            Device[]
  kyc                KycRecord?
  notifications      Notification[]
  otpRequests        OtpRequest[]
  portfolios         Portfolio[]
  profile            Profile?
  quizAttempts       QuizAttempt[]
  refreshTokens      RefreshToken[]
  riskProfile        RiskProfile?
  sessions           Session[]
  subscription       Subscription?
  supportTickets     SupportTicket[]
  transactions       Transaction[]
  wallet             Wallet?

  @@index([createdAt])
}

model Profile {
  id                String   @id @default(uuid())
  userId            String   @unique
  firstName         String
  lastName          String
  address           String?
  avatarUrl         String?
  updatedAt         DateTime @updatedAt
  baseCurrency      String?  @default("USD")
  city              String?
  communicationPref String?  @default("Email")
  country           String?  @default("Kenya")
  county            String?
  dob               String?
  experience        String?  @default("Beginner")
  gender            String?
  leverage          String?  @default("1:100")
  middleName        String?
  nationalId        String?
  nationality       String?
  occupation        String?
  postalCode        String?
  preferredAssets   String?  @default("BTC/USD")
  primaryMarket     String?  @default("Crypto")
  riskAppetite      String?  @default("Moderate")
  secondaryEmail    String?
  state             String?
  timezone          String?  @default("EAT (UTC+3)")
  tradingSession    String?  @default("London")
  tradingStyle      String?  @default("Day Trading")
  username          String?
  brokerType        String?  @default("None")
  brokerKey         String?
  brokerSecret      String?
  brokerServer      String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id         String   @id @default(uuid())
  userId     String
  provider   String
  providerId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wallet {
  id            String        @id @default(uuid())
  userId        String        @unique
  balance       Float         @default(0.0)
  marginBalance Float         @default(0.0)
  frozenBalance Float         @default(0.0)
  currency      String        @default("USD")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  transactions  Transaction[]
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id        String            @id @default(uuid())
  walletId  String
  userId    String
  type      TransactionType
  amount    Float
  status    TransactionStatus @default(PENDING)
  txHash    String?
  paymentId String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet    Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
}

model Portfolio {
  id                   String        @id @default(uuid())
  userId               String
  name                 String        @default("Default Portfolio")
  diversificationScore Float         @default(100.0)
  riskScore            Float         @default(0.0)
  sharpeRatio          Float         @default(0.0)
  maxDrawdown          Float         @default(0.0)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  assets               Asset[]
  orders               Order[]
  performances         Performance[]
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports              Report[]
  trades               Trade[]
}

model Asset {
  id           String    @id @default(uuid())
  portfolioId  String
  symbol       String
  quantity     Float
  averagePrice Float
  currentPrice Float
  updatedAt    DateTime  @updatedAt
  portfolio    Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model MarketData {
  id          String   @id @default(uuid())
  symbol      String   @unique
  bidPrice    Float
  askPrice    Float
  volume24h   Float
  lastUpdated DateTime @default(now())
}

model HistoricalCandle {
  id        String   @id @default(uuid())
  symbol    String
  interval  String
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  timestamp DateTime

  @@unique([symbol, interval, timestamp])
  @@index([symbol, timestamp])
}

model Order {
  id           String         @id @default(uuid())
  portfolioId  String
  symbol       String
  direction    OrderDirection
  type         OrderType
  quantity     Float
  price        Float?
  stopLoss     Float?
  takeProfit   Float?
  status       OrderStatus    @default(PENDING)
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  portfolio    Portfolio      @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  trades       Trade[]
}

model Trade {
  id             String         @id @default(uuid())
  portfolioId    String
  orderId        String
  symbol         String
  direction      OrderDirection
  quantity       Float
  executionPrice Float
  commission     Float          @default(0.0)
  executedAt     DateTime       @default(now())
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  portfolio      Portfolio      @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model Signal {
  id               String         @id @default(uuid())
  symbol           String
  direction        OrderDirection
  entryPrice       Float
  stopLoss         Float
  takeProfit1      Float
  takeProfit2      Float
  riskRewardRatio  Float
  winProbability   Float
  durationEstimate String
  aiReasoning      Json
  createdAt        DateTime       @default(now())
  expiresAt        DateTime

  @@index([symbol, expiresAt])
}

model TradingStrategy {
  id               String  @id @default(uuid())
  name             String
  description      String
  historicalReturn Float
  winRate          Float
  riskScore        Int
  maxDrawdown      Float
  isActive         Boolean @default(true)
}

model Performance {
  id          String    @id @default(uuid())
  portfolioId String
  balance     Float
  profit      Float
  drawdown    Float
  timestamp   DateTime  @default(now())
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model Report {
  id          String    @id @default(uuid())
  portfolioId String
  title       String
  fileUrl     String
  createdAt   DateTime  @default(now())
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model Course {
  id           String        @id @default(uuid())
  title        String
  description  String
  difficulty   String
  certificates Certificate[]
  lessons      Lesson[]
}

model Lesson {
  id           String        @id @default(uuid())
  courseId     String
  title        String
  content      String
  orderIndex   Int
  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quizzes      Quiz[]
  quizAttempts QuizAttempt[]
}

model Quiz {
  id            String   @id @default(uuid())
  lessonId      String
  question      String
  options       String[]
  correctOption Int
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id          String   @id @default(uuid())
  userId      String
  lessonId    String
  score       Float
  passed      Boolean
  completedAt DateTime @default(now())
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Certificate {
  id       String   @id @default(uuid())
  userId   String
  courseId String
  issuedAt DateTime @default(now())
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   Json
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model KycRecord {
  id           String    @id @default(uuid())
  userId       String    @unique
  status       KycStatus @default(UNVERIFIED)
  documentType String?
  documentUrl  String?
  faceVerified Boolean   @default(false)
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AmlRecord {
  id                 String   @id @default(uuid())
  userId             String
  riskClassification String
  isSanctioned       Boolean  @default(false)
  flaggedReason      String?
  checkedAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Device {
  id         String   @id @default(uuid())
  userId     String
  ipAddress  String
  deviceInfo String
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  ipAddress String
  userAgent String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RiskEvent {
  id        String   @id @default(uuid())
  title     String
  severity  String
  details   Json
  timestamp DateTime @default(now())
}

model AutomationRule {
  id          String   @id @default(uuid())
  userId      String
  name        String
  strategy    String
  allocation  Float
  riskLimit   Float
  maxDrawdown Float
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BacktestResult {
  id           String   @id @default(uuid())
  strategy     String
  symbol       String
  timeframe    String
  winRate      Float
  profitFactor Float
  maxDrawdown  Float
  totalTrades  Int
  results      Json
  createdAt    DateTime @default(now())
}

model AIConversation {
  id        String   @id @default(uuid())
  userId    String
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        String    @id @default(uuid())
  userId    String
  name      String
  keyHash   String    @unique
  scopes    String[]
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpRequest {
  id        String   @id @default(uuid())
  userId    String
  type      String
  channel   String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RiskProfile {
  id             String          @id @default(uuid())
  userId         String          @unique
  riskTolerance  AiMode          @default(BALANCED)
  maxLeverage    Float           @default(1.0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  dailyLossRules DailyLossRule[]
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyLossRule {
  id                  String      @id @default(uuid())
  riskProfileId       String
  maxDailyLossPercent Float
  currentDailyLoss    Float       @default(0.0)
  isTriggered         Boolean     @default(false)
  updatedAt           DateTime    @updatedAt
  riskProfile         RiskProfile @relation(fields: [riskProfileId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String
  subject   String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id        String             @id @default(uuid())
  userId    String             @unique
  plan      PlanType
  status    SubscriptionStatus
  startDate DateTime           @default(now())
  endDate   DateTime?
  autoRenew Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  COMPLIANCE_OFFICER
  SUPPORT_AGENT
  TRADER
  INVESTOR
  GUEST
  AI_AGENT
}

enum AiMode {
  CONSERVATIVE
  BALANCED
  AGGRESSIVE
  CUSTOM
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  FEE
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REJECTED
  UNDER_REVIEW
}

enum OrderDirection {
  BUY
  SELL
  WAIT
}

enum OrderType {
  MARKET
  LIMIT
  STOP_LOSS
  TAKE_PROFIT
}

enum OrderStatus {
  PENDING
  FILLED
  PARTIALLY_FILLED
  CANCELLED
  REJECTED
}

enum KycStatus {
  UNVERIFIED
  PENDING
  APPROVED
  REJECTED
}

enum PlanType {
  STARTER
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}
